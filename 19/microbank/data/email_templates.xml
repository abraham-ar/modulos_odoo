<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="S" model="mail.template">
            <field name="name">Loan Approved Notification</field>
            <field name="model_id" ref="model_loan_application"/>
            <field name="subject">Su solicitud de préstamo ha sido aprobada</field>
            <field name="email_to">{{ object.partner_id.email }}</field>

            <field name="body_html" type="html">
                <div>
                    <p>
                        Estimado <t t-out="object.partner_id.name or ''"/>,
                    </p>

                    <p>
                        Su solicitud de préstamo por
                        <strong>
                            <t t-out="format_amount(object.loan_amount, object.currency_id)"/>
                        </strong>
                        ha sido aprobada.
                    </p>

                    <p>
                        Saludos cordiales.
                    </p>
                </div>
            </field>
        </record>

        <record id="email_template_loan_rejected" model="mail.template">
            <field name="name">Loan Rejected Notification</field>
            <field name="model_id" ref="model_loan_application"/>
            <field name="subject">Su solicitud de préstamo ha sido rechazada</field>
            <field name="email_to">{{ object.partner_id.email }}</field>

            <field name="body_html" type="html">
                <div>
                    <p>
                        Estimado <t t-out="object.partner_id.name or ''"/>,
                    </p>

                    <p>
                        Su solicitud de préstamo ha sido rechazada.
                        Si desea conocer más detalles, visite su sucursal más cercana.
                    </p>

                    <p>
                        Saludos cordiales.
                    </p>
                </div>
            </field>
        </record>
    </data>
</odoo>
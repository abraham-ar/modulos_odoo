<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_microbank_loan_payment_form" model="ir.ui.view">
        <field name="name">microbank.loan.payment.form</field>
        <field name="model">loan.payment</field>
        <field name="group_ids" eval="[
            (4, ref('microbank.group_cashier')),
            (4, ref('microbank.group_admin'))
        ]"/>
        <field name="arch" type="xml">
            <form string="Pago">
                <header>
                    <button name="action_confirmar" type="object" string="Confirmar" invisible="state != 'borrador'"
                            class="oe_highlight"/>
                    <button name="action_cancelar" type="object" string="Cancelar" invisible="state != 'borrador'"/>
                    <field name="state" widget="statusbar" statusbar_visible="borrador,confirmado"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="loan_id" readonly="state == 'confirmado'"/>
                            <field name="payment_date"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="state"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_microbank_loan_payment_tree" model="ir.ui.view">
        <field name="name">microbank.loan.payment.tree</field>
        <field name="model">loan.payment</field>
        <field name="group_ids" eval="[
                (4, ref('microbank.group_cashier')),
                (4, ref('microbank.group_admin'))
            ]"/>
        <field name="arch" type="xml">
            <list string="Pagos">
                <field name="loan_id"/>
                <field name="payment_date"/>
                <field name="amount"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_microbank_loan_payment_calendar" model="ir.ui.view">
        <field name="name">microbank.loan.payment.calendar</field>
        <field name="model">loan.payment</field>
        <field name="arch" type="xml">
            <calendar date_start="payment_date" mode="year">
                <field name="loan_id"/>
            </calendar>
        </field>
    </record>

    <record id="view_microbank_loan_payment_search" model="ir.ui.view">
        <field name="name">microbank.loan.payment.search</field>
        <field name="model">loan.payment</field>
        <field name="arch" type="xml">
            <search string="Pagos">
                <field name="loan_id"/>
                <field name="amount"/>
                <filter string="Por confirmar" name="draft_loan_payment"
                        domain="[('state', '=', 'borrador')]"/>
                <filter string="Confirmados" name="approved_loan_payment"
                        domain="[('state', '=', 'confirmado')]"/>
                <filter string="Cancelados" name="canceled_loan_payment"
                        domain="[('state', '=', 'cancelado')]"/>
                <group>
                    <filter string="Por prestamo" name="group_by_loan_id" context="{'group_by': 'loan_id'}"/>
                </group>
                <group>
                    <filter string="Por estado del pago" name="group_by_state" context="{'group_by': 'state'}"/>
                </group>
                <group>
                    <filter string="Por fecha de pago" name="group_by_payment_date" context="{'group_by': 'payment_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_microbank_loan_payment" model="ir.actions.act_window">
        <field name="name">Pagos</field>
        <field name="res_model">loan.payment</field>
        <field name="view_mode">list,calendar,form</field>
        <field name="search_view_id" ref="view_microbank_loan_payment_search"/>
        <field name="view_ids" eval="[Command.clear(),
                          (0,0,{'view_mode':'list', 'view_id': ref('view_microbank_loan_payment_tree')}),
                          (0,0,{'view_mode':'form', 'view_id': ref('view_microbank_loan_payment_form')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aún no hay pagos registrados
            </p>
        </field>
    </record>
</odoo>
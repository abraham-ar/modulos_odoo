<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_microbank_loan_application_form" model="ir.ui.view">
        <field name="name">microbank.loan.application.form</field>
        <field name="model">loan.application</field>
        <field name="group_ids" eval="[(4, ref('microbank.group_analyst'))]"/>
        <field name="arch" type="xml">
            <form string="Prestamo">
                <header>
                    <button name="action_aprobar" type="object" string="Aprobar" invisible="state != 'borrador'"
                            class="oe_highlight"/>
                    <button name="action_pagar" type="object" string="Marcar como pagado"
                            invisible="state != 'aprobado'"
                            class="oe_highlight"/>
                    <button name="action_rechazar" type="object" string="Rechazar" invisible="state != 'borrador'"/>
                    <field name="state" widget="statusbar" statusbar_visible="borrador,aprobado,pagado"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="True"/>
                            <field name="partner_id"/>
                            <field name="loan_amount"/>
                            <field name="interest_rate"/>
                            <field name="term_months"/>
                        </group>
                        <group>
                            <field name="monthly_payment" readonly="True"/>
                            <field name="total_to_pay" readonly="True"/>
                            <field name="approval_date"/>
                            <field name="next_payment_date"/>
                            <field name="progress" widget="percentpie"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_microbank_loan_application_tree" model="ir.ui.view">
        <field name="name">microbank.loan.application.tree</field>
        <field name="model">loan.application</field>
        <field name="group_ids" eval="[
        (4, ref('microbank.group_analyst')),
        (4, ref('microbank.group_manager')),
         (4, ref('microbank.group_cashier'))
        ]"/>
        <field name="arch" type="xml">
            <list string="Prestamos">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="loan_amount" optional="show"/>
                <field name="interest_rate" optional="show"/>
                <field name="term_months" optional="show"/>
                <field name="state" optional="show"/>
                <field name="monthly_payment" optional="show"/>
                <field name="total_to_pay" optional="show"/>
                <field name="approval_date" optional="show"/>
                <field name="next_payment_date" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_microbank_loan_application_kanban" model="ir.ui.view">
        <field name="name">microbank.loan.application.kanban</field>
        <field name="model">loan.application</field>
        <field name="group_ids" eval="[
        (4, ref('microbank.group_analyst'))
        ]"/>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="state"/>
                <field name="progress"/>
                <templates>
                    <t t-name="card">
                        <div>
                            <strong>
                                <field name="name"/>
                            </strong>
                        </div>
                        <div>
                            <strong>
                                Cliente:
                            </strong>
                            <field name="partner_id"/>
                        </div>
                        <div>
                            <strong>
                                Estado:
                            </strong>
                            <field name="state"/>
                        </div>
                        <div>
                            <strong>
                                Progreso de pago:
                            </strong>
                            <field name="progress" widget="progressbar"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>


    <record id="action_microbank_loan_application" model="ir.actions.act_window">
        <field name="name">Prestamos</field>
        <field name="res_model">loan.application</field>
        <field name="view_mode">list,kanban,form,search</field>
        <field name="view_ids" eval="[Command.clear(),
                          (0,0,{'view_mode':'list', 'view_id': ref('view_microbank_loan_application_tree')}),
                          (0,0,{'view_mode':'form', 'view_id': ref('view_microbank_loan_application_form')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea una nueva solicitud de prestamo
            </p>
        </field>
    </record>
</odoo>